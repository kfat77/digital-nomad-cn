{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Country Detail",
  "description": "数字游民指南 - 国家详情数据结构",
  "type": "object",
  "required": ["id", "name", "name_en", "code_iso_3166_1", "region", "sub_region", "coordinates", "timezone", "currency", "languages", "population", "area_km2", "gdp_per_capita_usd", "hdi", "safety_index", "internet_speed_avg_mbps", "cost_of_living_index", "rent_index", "china_passport_visa_status", "digital_nomad_score", "tags", "status", "updated_at"],
  "properties": {
    "id": {"type": "string", "description": "唯一标识符"},
    "name": {"type": "string", "description": "中文名"},
    "name_en": {"type": "string", "description": "英文名"},
    "name_local": {"type": "string", "description": "本地语言名"},
    "code_iso_3166_1": {"type": "string", "description": "ISO 3166-1 alpha-2"},
    "code_iso_3166_3": {"type": "string", "description": "ISO 3166-1 alpha-3"},
    "region": {"type": "string", "enum": ["asia", "europe", "americas_north", "americas_south", "oceania", "africa", "middle_east"]},
    "sub_region": {"type": "string"},
    "is_special_admin_region": {"type": "boolean"},
    "is_digital_nomad_friendly": {"type": "boolean"},
    "has_digital_nomad_visa": {"type": "boolean"},
    "coordinates": {"type": "object", "properties": {"lat": {"type": "number"}, "lon": {"type": "number"}}},
    "timezone": {"type": "array", "items": {"type": "string"}},
    "currency": {"type": "array", "items": {"type": "object", "properties": {"code": {"type": "string"}, "name": {"type": "string"}, "is_primary": {"type": "boolean"}}}},
    "languages": {"type": "array", "items": {"type": "object", "properties": {"code": {"type": "string"}, "name": {"type": "string"}, "is_official": {"type": "boolean"}}}},
    "population": {"type": "integer"},
    "area_km2": {"type": "integer"},
    "gdp_per_capita_usd": {"type": "integer"},
    "hdi": {"type": "number", "minimum": 0, "maximum": 1},
    "safety_index": {"type": "number"},
    "internet_speed_avg_mbps": {"type": "number"},
    "cost_of_living_index": {"type": "number"},
    "rent_index": {"type": "number"},
    "china_passport_visa_status": {"type": "string", "enum": ["visa_free", "visa_on_arrival", "evisa", "visa_required", "eta", "special_permit"]},
    "china_passport_visa_note": {"type": "string"},
    "digital_nomad_score": {"type": "integer", "minimum": 0, "maximum": 100},
    "tags": {"type": "array", "items": {"type": "string"}},
    "status": {"type": "string", "enum": ["draft", "published", "archived"]},
    "updated_at": {"type": "string", "format": "date-time"},
    "source": {"type": "string"}
  }
}
