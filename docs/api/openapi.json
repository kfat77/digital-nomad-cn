{
  "openapi": "3.0.3",
  "info": {
    "title": "Digital Nomad Guide API",
    "description": "Open data infrastructure for digital nomads and global mobility. Structured JSON data covering 60 countries, 122 cities, visa policies, and statistics. No authentication required.\n\nAll data is licensed under CC BY-NC-SA 4.0.",
    "version": "1.2.0",
    "contact": {
      "name": "Digital Nomad Guide",
      "url": "https://github.com/kfat77/digital-nomad-cn"
    },
    "license": {
      "name": "CC BY-NC-SA 4.0",
      "url": "https://creativecommons.org/licenses/by-nc-sa/4.0/"
    }
  },
  "servers": [
    {
      "url": "https://kfat77.github.io/digital-nomad-cn",
      "description": "Production (GitHub Pages)"
    }
  ],
  "paths": {
    "/api/countries.json": {
      "get": {
        "summary": "Get all countries data",
        "description": "Returns structured data for 60 countries covering cost of living, safety, internet speed, visa status, and deep-dive fields.",
        "operationId": "getCountries",
        "tags": ["Countries"],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CountriesResponse"
                },
                "example": {
                  "api_version": "1.2",
                  "total": 60,
                  "updated_at": "2026-07-09T00:00:00Z",
                  "data": [
                    {
                      "id": "thailand",
                      "name": "泰国",
                      "name_en": "Thailand",
                      "region": "东南亚",
                      "digital_nomad_score": 82,
                      "cost_of_living_index": 35,
                      "safety_index": 65,
                      "internet_speed_avg_mbps": 150,
                      "china_passport_visa_status": "visa_free",
                      "has_digital_nomad_visa": true,
                      "climate_zone": "热带",
                      "timezone": "UTC+7",
                      "dn_community_size": "大",
                      "median_stay_months": 6,
                      "hdi": 0.800,
                      "healthcare_quality": 65,
                      "english_proficiency": 50,
                      "rent_one_bedroom_usd": 400,
                      "meal_avg_usd": 3,
                      "transport_monthly_usd": 30,
                      "tax_rate_percent": 15,
                      "pros": ["生活成本低", "美食天堂", "友好当地人"],
                      "cons": ["签证需定期出境", "空气质量有时差", "语言障碍"],
                      "ideal_for": ["预算型游民", "美食爱好者", "热带气候爱好者"],
                      "top_neighborhoods": ["Canggu", "Ubud", "Seminyak"]
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/cities.json": {
      "get": {
        "summary": "Get all cities data",
        "description": "Returns structured data for 122 digital nomad cities including coworking spaces, climate, neighborhoods, and costs.",
        "operationId": "getCities",
        "tags": ["Cities"],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CitiesResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/visas.json": {
      "get": {
        "summary": "Get visa data by country",
        "description": "Returns visa requirements for all 60 countries for Chinese passport holders.",
        "operationId": "getVisas",
        "tags": ["Visas"],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VisasResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/stats.json": {
      "get": {
        "summary": "Get platform statistics",
        "description": "Returns aggregated statistics and metadata about the dataset.",
        "operationId": "getStats",
        "tags": ["Statistics"],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatsResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/manifest.json": {
      "get": {
        "summary": "Get API manifest",
        "description": "AI Agent discovery endpoint. Lists all available endpoints with schemas and examples.",
        "operationId": "getManifest",
        "tags": ["Discovery"],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ManifestResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CountriesResponse": {
        "type": "object",
        "properties": {
          "api_version": { "type": "string", "example": "1.2" },
          "total": { "type": "integer", "example": 60 },
          "updated_at": { "type": "string", "format": "date-time" },
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Country" }
          }
        }
      },
      "Country": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "URL-safe identifier", "example": "thailand" },
          "name": { "type": "string", "description": "Country name in Chinese", "example": "泰国" },
          "name_en": { "type": "string", "description": "Country name in English", "example": "Thailand" },
          "region": { "type": "string", "example": "东南亚" },
          "digital_nomad_score": { "type": "integer", "minimum": 0, "maximum": 100, "description": "Composite score (cost 30%, safety 25%, internet 20%, visa 15%, community 10%)" },
          "cost_of_living_index": { "type": "integer", "minimum": 0, "maximum": 100, "description": "Relative to NYC=100" },
          "safety_index": { "type": "integer", "minimum": 0, "maximum": 100 },
          "internet_speed_avg_mbps": { "type": "integer", "minimum": 0, "maximum": 500 },
          "china_passport_visa_status": { "type": "string", "enum": ["visa_free", "visa_on_arrival", "evisa", "visa_required"], "description": "Chinese passport visa requirement" },
          "has_digital_nomad_visa": { "type": "boolean" },
          "climate_zone": { "type": "string", "enum": ["地中海", "热带", "温带", "大陆性", "亚热带", "极地", "沙漠"], "example": "热带" },
          "timezone": { "type": "string", "example": "UTC+7" },
          "dn_community_size": { "type": "string", "enum": ["大", "中", "小"], "example": "大" },
          "median_stay_months": { "type": "integer", "description": "Typical nomad stay duration" },
          "hdi": { "type": "number", "minimum": 0, "maximum": 1, "description": "Human Development Index" },
          "healthcare_quality": { "type": "integer", "minimum": 0, "maximum": 100 },
          "english_proficiency": { "type": "integer", "minimum": 0, "maximum": 100 },
          "rent_one_bedroom_usd": { "type": "integer", "description": "Average monthly rent for 1-bedroom apartment" },
          "meal_avg_usd": { "type": "number", "description": "Average meal cost" },
          "transport_monthly_usd": { "type": "integer", "description": "Monthly transport pass cost" },
          "tax_rate_percent": { "type": "number", "description": "Income tax rate for foreigners" },
          "pros": { "type": "array", "items": { "type": "string" }, "description": "Top 3 advantages for nomads" },
          "cons": { "type": "array", "items": { "type": "string" }, "description": "Top 3 disadvantages for nomads" },
          "ideal_for": { "type": "array", "items": { "type": "string" }, "description": "3 ideal nomad profiles" },
          "top_neighborhoods": { "type": "array", "items": { "type": "string" }, "description": "3 recommended neighborhoods" }
        }
      },
      "CitiesResponse": {
        "type": "object",
        "properties": {
          "api_version": { "type": "string" },
          "total": { "type": "integer" },
          "updated_at": { "type": "string", "format": "date-time" },
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/City" }
          }
        }
      },
      "City": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "name_en": { "type": "string" },
          "country_id": { "type": "string" },
          "country_name": { "type": "string" },
          "digital_nomad_score": { "type": "integer", "minimum": 0, "maximum": 100 },
          "cost_of_living_index": { "type": "integer", "minimum": 0, "maximum": 100 },
          "rent_index": { "type": "integer", "minimum": 0, "maximum": 100 },
          "safety_index": { "type": "integer", "minimum": 0, "maximum": 100 },
          "internet_speed_avg_mbps": { "type": "integer", "minimum": 0, "maximum": 500 },
          "coworking_spaces": { "type": "integer", "description": "Number of coworking spaces" },
          "coworking_score": { "type": "integer", "minimum": 0, "maximum": 100 },
          "remote_work_friendly_score": { "type": "integer", "minimum": 0, "maximum": 100 },
          "monthly_cost_usd_low": { "type": "integer", "description": "Minimum monthly budget" },
          "monthly_cost_usd_high": { "type": "integer", "description": "Maximum monthly budget" },
          "climate": { "type": "string", "description": "Climate description" },
          "avg_temp_c": { "type": "number", "description": "Average temperature in Celsius" },
          "rainy_season": { "type": "string", "description": "Rainy months" },
          "english_level": { "type": "string", "enum": ["高", "中", "低"] },
          "chinese_community_size": { "type": "string", "enum": ["大", "中", "小"] },
          "walkability": { "type": "integer", "minimum": 0, "maximum": 100 },
          "bike_friendly": { "type": "integer", "minimum": 0, "maximum": 100 },
          "description": { "type": "string", "description": "City overview" }
        }
      },
      "VisasResponse": {
        "type": "object",
        "properties": {
          "api_version": { "type": "string" },
          "total": { "type": "integer" },
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Visa" }
          }
        }
      },
      "Visa": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "country_id": { "type": "string" },
          "country_name": { "type": "string" },
          "visa_types": { "type": "array", "items": { "type": "object" } },
          "updated_at": { "type": "string", "format": "date-time" },
          "source": { "type": "string" }
        }
      },
      "StatsResponse": {
        "type": "object",
        "properties": {
          "api_version": { "type": "string" },
          "updated_at": { "type": "string", "format": "date-time" },
          "countries": {
            "type": "object",
            "properties": {
              "total": { "type": "integer" },
              "avg_digital_nomad_score": { "type": "number" },
              "avg_cost_of_living_index": { "type": "number" },
              "avg_safety_index": { "type": "number" },
              "avg_internet_speed": { "type": "number" },
              "by_visa_status": { "type": "object" },
              "by_region": { "type": "object" }
            }
          }
        }
      },
      "ManifestResponse": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "example": "Digital Nomad Guide API" },
          "version": { "type": "string", "example": "1.2.0" },
          "description": { "type": "string" },
          "endpoints": { "type": "array", "items": { "type": "object" } },
          "license": { "type": "string", "example": "CC BY-NC-SA 4.0" },
          "last_updated": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}
