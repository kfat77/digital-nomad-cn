{
  "name": "Digital Nomad CN Data API",
  "description": "面向中国用户的全球数字游民结构化开放数据基础设施。覆盖60个国家、122个城市、签证政策、生活成本、安全指数、网速评分等维度。无需认证，CC BY-NC-SA 4.0 协议。",
  "version": "1.3.0",
  "base_url": "https://kfat77.github.io/digital-nomad-cn/api/",
  "homepage": "https://kfat77.github.io/digital-nomad-cn/",
  "source_repo": "https://github.com/kfat77/digital-nomad-cn",
  "license": "CC BY-NC-SA 4.0",
  "updated_at": "2026-07-06T19:53:26Z",
  "formats": [
    "json"
  ],
  "languages": [
    "zh-CN",
    "en"
  ],
  "endpoints": {
    "countries": {
      "url": "countries.json",
      "method": "GET",
      "description": "获取60个国家完整数据，包含生活成本、安全、网速、签证、HDI、GDP等维度",
      "count": 60,
      "schema": "https://kfat77.github.io/digital-nomad-cn/data/schemas/country-detail.json",
      "openapi_ref": "#/components/schemas/CountriesResponse",
      "example": "https://kfat77.github.io/digital-nomad-cn/api/countries.json",
      "fields": [
        "id",
        "name",
        "name_en",
        "region",
        "sub_region",
        "digital_nomad_score",
        "cost_of_living_index",
        "safety_index",
        "internet_speed_avg_mbps",
        "rent_index",
        "hdi",
        "gdp_per_capita_usd",
        "china_passport_visa_status",
        "has_digital_nomad_visa",
        "coordinates",
        "currency",
        "languages",
        "timezone",
        "population",
        "area_km2",
        "tags"
      ]
    },
    "cities": {
      "url": "cities.json",
      "method": "GET",
      "description": "获取122个数字游民城市数据，包含联合办公、气候、社区、街区等",
      "count": 122,
      "schema": "https://kfat77.github.io/digital-nomad-cn/data/schemas/city-detail.json",
      "openapi_ref": "#/components/schemas/CitiesResponse",
      "example": "https://kfat77.github.io/digital-nomad-cn/api/cities.json",
      "fields": [
        "id",
        "name",
        "name_en",
        "country_id",
        "country_name",
        "digital_nomad_score",
        "cost_of_living_index",
        "rent_index",
        "safety_index",
        "internet_speed_avg_mbps",
        "coworking_spaces",
        "coworking_score",
        "climate",
        "avg_temp_c",
        "rainy_season",
        "english_level",
        "chinese_community_size",
        "neighborhoods",
        "food_scene",
        "nightlife",
        "transportation",
        "walkability",
        "bike_friendly",
        "description"
      ]
    },
    "visas": {
      "url": "visas.json",
      "method": "GET",
      "description": "获取中国护照持有者的签证政策数据，覆盖免签、电子签、落地签、需签证等类型",
      "count": 60,
      "schema": "https://kfat77.github.io/digital-nomad-cn/data/schemas/visa-detail.json",
      "openapi_ref": "#/components/schemas/VisasResponse",
      "example": "https://kfat77.github.io/digital-nomad-cn/api/visas.json",
      "fields": [
        "id",
        "country_id",
        "country_name",
        "visa_types",
        "updated_at",
        "source"
      ]
    },
    "stats": {
      "url": "stats.json",
      "method": "GET",
      "description": "获取平台聚合统计数据和元数据",
      "schema": null,
      "openapi_ref": "#/components/schemas/StatsResponse",
      "example": "https://kfat77.github.io/digital-nomad-cn/api/stats.json"
    },
    "openapi": {
      "url": "openapi.json",
      "method": "GET",
      "description": "OpenAPI 3.0.3 规范文档，包含完整的路径定义和 JSON Schema",
      "format": "openapi",
      "example": "https://kfat77.github.io/digital-nomad-cn/api/openapi.json"
    },
    "schema_registry": {
      "url": "schema.json",
      "method": "GET",
      "description": "JSON Schema 注册中心，列出所有可用 schema",
      "format": "json-schema-registry",
      "example": "https://kfat77.github.io/digital-nomad-cn/api/schema.json"
    }
  },
  "schemas": {
    "country": "https://kfat77.github.io/digital-nomad-cn/data/schemas/country-detail.json",
    "city": "https://kfat77.github.io/digital-nomad-cn/data/schemas/city-detail.json",
    "visa": "https://kfat77.github.io/digital-nomad-cn/data/schemas/visa-detail.json"
  },
  "ai_usage": {
    "agent_prompt": "You are an AI agent with access to the Digital Nomad CN open data API. Use the endpoints below to retrieve structured data about digital nomad destinations, visa policies, and city information. All data is free, no authentication required. Base URL: https://kfat77.github.io/digital-nomad-cn/api/",
    "capabilities": [
      "Query 60 countries with cost-of-living, safety, internet speed, visa status",
      "Query 122 cities with coworking spaces, climate, neighborhoods",
      "Query visa requirements for Chinese passport holders",
      "Get aggregated statistics and trends",
      "Filter and compare destinations by any numeric field"
    ],
    "example_requests": [
      "GET https://kfat77.github.io/digital-nomad-cn/api/countries.json → 60个国家完整数据",
      "GET https://kfat77.github.io/digital-nomad-cn/api/cities.json → 122个城市完整数据",
      "GET https://kfat77.github.io/digital-nomad-cn/api/visas.json → 签证政策数据",
      "GET https://kfat77.github.io/digital-nomad-cn/api/stats.json → 聚合统计",
      "GET https://kfat77.github.io/digital-nomad-cn/api/openapi.json → OpenAPI 规范",
      "GET https://kfat77.github.io/digital-nomad-cn/api/schema.json → Schema 注册中心"
    ],
    "mcp_hint": "If you are an MCP client, read api/manifest.json first, then fetch the endpoint you need. All responses are JSON arrays or objects."
  }
}