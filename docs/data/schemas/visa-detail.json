{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Visa Detail",
  "description": "数字游民指南 - 签证详情数据结构",
  "type": "object",
  "required": ["country_id", "country_name", "updated_at", "visa_types"],
  "properties": {
    "country_id": { "type": "string", "description": "关联国家ID" },
    "country_name": { "type": "string", "description": "中文名" },
    "updated_at": { "type": "string", "format": "date-time" },
    "source": { "type": "string", "description": "数据来源" },
    "visa_types": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "name", "china_passport_eligible"],
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string", "enum": ["visa_free", "visa_on_arrival", "evisa", "visa_required", "eta", "digital_nomad_visa", "work_visa", "business_visa", "student_visa", "special_permit"] },
          "name": { "type": "string", "description": "中文名" },
          "name_en": { "type": "string", "description": "英文名" },
          "duration": { "type": "string", "description": "停留时长" },
          "validity": { "type": "string", "description": "签证有效期" },
          "extendable": { "type": "boolean" },
          "extend_duration": { "type": "string", "description": "可延期时长" },
          "fee_usd": { "type": "number" },
          "processing_days": { "type": "integer" },
          "application_method": { "type": "string", "enum": ["on_arrival", "online", "embassy", "agent", "mail"] },
          "requirements": { "type": "array", "items": { "type": "string" } },
          "documents": { "type": "array", "items": { "type": "string" } },
          "official_url": { "type": "string", "format": "uri" },
          "china_passport_eligible": { "type": "boolean" },
          "notes": { "type": "string" },
          "is_recommended_for_digital_nomad": { "type": "boolean" }
        }
      }
    }
  }
}
