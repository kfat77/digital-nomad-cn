{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "City Detail",
  "description": "数字游民指南 - 城市详情数据结构",
  "type": "object",
  "required": ["id", "name", "name_en", "country_id", "country_name", "digital_nomad_score", "cost_of_living_index", "rent_index", "safety_index", "internet_speed_avg_mbps", "coworking_spaces", "coworking_score", "climate", "avg_temp_c", "english_level", "status", "updated_at"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "name_en": { "type": "string" },
    "country_id": { "type": "string" },
    "country_name": { "type": "string" },
    "digital_nomad_score": { "type": "integer", "minimum": 0, "maximum": 100 },
    "cost_of_living_index": { "type": "number" },
    "rent_index": { "type": "number" },
    "safety_index": { "type": "number" },
    "internet_speed_avg_mbps": { "type": "number" },
    "coworking_spaces": { "type": "integer" },
    "coworking_score": { "type": "integer", "minimum": 0, "maximum": 100 },
    "climate": { "type": "string" },
    "avg_temp_c": { "type": "number" },
    "rainy_season": { "type": "string" },
    "english_level": { "type": "string" },
    "chinese_community_size": { "type": "string" },
    "neighborhoods": { "type": "array", "items": { "type": "string" } },
    "food_scene": { "type": "string" },
    "nightlife": { "type": "string" },
    "transportation": { "type": "string" },
    "walkability": { "type": "integer", "minimum": 0, "maximum": 100 },
    "bike_friendly": { "type": "integer", "minimum": 0, "maximum": 100 },
    "description": { "type": "string" },
    "status": { "type": "string", "enum": ["draft", "published", "archived"] },
    "updated_at": { "type": "string", "format": "date-time" },
    "source": { "type": "string" }
  }
}
