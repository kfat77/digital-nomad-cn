{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/kfat77/digital-nomad-cn/schemas/v2/living/cost.schema.json",
  "title": "CostOfLiving",
  "description": "生活成本数据。按国家和城市定义，包含各项支出明细。",
  "version": "2.0.0",
  "type": "object",
  "required": ["location", "monthlyCosts", "metadata"],
  "properties": {
    "location": {
      "type": "object",
      "required": ["country", "city"],
      "properties": {
        "country": { "type": "string", "description": "国家ID" },
        "city": { "type": "string", "description": "城市ID（可选，国家级数据可留空）" },
        "region": { "type": "string", "description": "区域/省份" }
      }
    },
    "referenceDate": {
      "type": "string",
      "format": "date",
      "description": "数据参考日期"
    },
    "currency": {
      "type": "string",
      "pattern": "^[A-Z]{3}$",
      "default": "USD",
      "description": "基准货币"
    },
    "exchangeRate": {
      "type": "object",
      "description": "对美元的汇率",
      "properties": {
        "rate": { "type": "number" },
        "date": { "type": "string", "format": "date" }
      }
    },
    "monthlyCosts": {
      "type": "object",
      "description": "月度支出明细",
      "properties": {
        "housing": {
          "type": "object",
          "description": "住宿",
          "properties": {
            "budget": {
              "type": "object",
              "properties": {
                "amount": { "type": "integer" },
                "description": { "type": "string", "examples": ["shared apartment", "hostel"] }
              }
            },
            "midRange": {
              "type": "object",
              "properties": {
                "amount": { "type": "integer" },
                "description": { "type": "string", "examples": ["1-bedroom apartment"] }
              }
            },
            "luxury": {
              "type": "object",
              "properties": {
                "amount": { "type": "integer" },
                "description": { "type": "string", "examples": ["2-bedroom serviced apartment"] }
              }
            }
          }
        },
        "food": {
          "type": "object",
          "description": "餐饮",
          "properties": {
            "streetFood": { "type": "integer" },
            "localRestaurant": { "type": "integer" },
            "westernRestaurant": { "type": "integer" },
            "groceries": { "type": "integer" }
          }
        },
        "transport": {
          "type": "object",
          "description": "交通",
          "properties": {
            "publicTransport": { "type": "integer" },
            "taxi": { "type": "integer" },
            "scooterRental": { "type": "integer" },
            "carRental": { "type": "integer" }
          }
        },
        "utilities": {
          "type": "object",
          "description": "水电网",
          "properties": {
            "electricity": { "type": "integer" },
            "water": { "type": "integer" },
            "internet": { "type": "integer" },
            "mobile": { "type": "integer" }
          }
        },
        "coworking": {
          "type": "object",
          "description": "联合办公",
          "properties": {
            "daily": { "type": "integer" },
            "monthly": { "type": "integer" },
            "cafeWork": { "type": "integer" }
          }
        },
        "entertainment": {
          "type": "object",
          "description": "娱乐",
          "properties": {
            "gym": { "type": "integer" },
            "cinema": { "type": "integer" },
            "nightlife": { "type": "integer" },
            "activities": { "type": "integer" }
          }
        },
        "insurance": {
          "type": "object",
          "description": "保险",
          "properties": {
            "travel": { "type": "integer" },
            "health": { "type": "integer" }
          }
        },
        "visa": {
          "type": "object",
          "description": "签证均摊费用",
          "properties": {
            "monthly": { "type": "integer", "description": "签证费用按月均摊" }
          }
        }
      }
    },
    "totalMonthly": {
      "type": "object",
      "description": "月度总成本（自动生成）",
      "properties": {
        "budget": { "type": "integer" },
        "midRange": { "type": "integer" },
        "luxury": { "type": "integer" }
      }
    },
    "oneTimeCosts": {
      "type": "object",
      "description": "一次性成本",
      "properties": {
        "deposit": { "type": "integer", "description": "租房押金" },
        "setup": { "type": "integer", "description": "安家费用" },
        "visa": { "type": "integer" },
        "flight": { "type": "integer" }
      }
    },
    "costIndex": {
      "type": "object",
      "description": "成本指数（相对于纽约=100）",
      "properties": {
        "overall": { "type": "number" },
        "rent": { "type": "number" },
        "food": { "type": "number" },
        "transport": { "type": "number" }
      }
    },
    "notes": {
      "type": "object",
      "properties": {
        "zh": { "type": "string" },
        "en": { "type": "string" }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["version", "lastUpdated"],
      "properties": {
        "version": { "type": "string" },
        "lastUpdated": { "type": "string", "format": "date-time" },
        "dataSource": {
          "type": "string",
          "enum": ["numbeo", "expatistan", "crowdsourced", "official", "estimate"]
        },
        "contributors": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "github": { "type": "string" },
              "name": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
