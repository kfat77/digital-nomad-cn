{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/kfat77/digital-nomad-cn/schemas/v2/infrastructure/coliving.schema.json",
  "title": "ColivingSpace",
  "description": "共居空间数据。数字游民友好型长租公寓/共居社区。",
  "version": "2.0.0",
  "type": "object",
  "required": ["country", "city", "spaces", "metadata"],
  "properties": {
    "country": { "type": "string" },
    "city": { "type": "string" },
    "spaces": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["dedicated", "apartment", "hotel", "hostel", "villa"]
          },
          "address": { "type": "string" },
          "coordinates": {
            "type": "object",
            "properties": {
              "latitude": { "type": "number" },
              "longitude": { "type": "number" }
            }
          },
          "website": { "type": "string", "format": "uri" },
          "pricing": {
            "type": "object",
            "properties": {
              "weekly": { "type": "integer" },
              "monthly": { "type": "integer" },
              "quarterly": { "type": "integer" },
              "currency": { "type": "string", "pattern": "^[A-Z]{3}$" }
            }
          },
          "roomTypes": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["private", "shared", "suite", "studio"]
            }
          },
          "amenities": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "wifi", "coworking-space", "kitchen", "laundry",
                "cleaning", "gym", "pool", "rooftop", "bbq",
                "community-events", "workshops", "yoga", "meditation",
                "pet-friendly", "parking", "airport-pickup"
              ]
            }
          },
          "community": {
            "type": "object",
            "properties": {
              "size": { "type": "integer" },
              "chineseSpeakers": { "type": "boolean" },
              "eventsFrequency": { "type": "string", "enum": ["daily", "weekly", "biweekly", "monthly"] }
            }
          },
          "minStay": { "type": "string", "examples": ["1 week", "1 month"] },
          "rating": {
            "type": "object",
            "properties": {
              "overall": { "type": "number", "minimum": 0, "maximum": 5 }
            }
          },
          "status": { "type": "string", "enum": ["active", "full", "closed"], "default": "active" }
        }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["version", "lastUpdated"],
      "properties": {
        "version": { "type": "string" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      }
    }
  }
}
