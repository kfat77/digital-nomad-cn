{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/kfat77/digital-nomad-cn/schemas/v2/infrastructure/insurance.schema.json",
  "title": "Insurance",
  "description": "保险数据。旅行保险和医疗保险建议。",
  "version": "2.0.0",
  "type": "object",
  "required": ["country", "recommendations", "metadata"],
  "properties": {
    "country": { "type": "string" },
    "localRequirement": {
      "type": "object",
      "properties": {
        "healthInsuranceMandatory": { "type": "boolean" },
        "minimumCoverage": { "type": "integer", "description": "最低保额（美元）" },
        "acceptedProviders": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["provider", "type"],
        "properties": {
          "provider": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["travel", "health", "evacuation", "gear", "liability"]
          },
          "coverage": {
            "type": "object",
            "properties": {
              "medical": { "type": "integer", "description": "医疗保额（美元）" },
              "evacuation": { "type": "integer" },
              "tripCancellation": { "type": "boolean" },
              "gear": { "type": "integer" }
            }
          },
          "cost": {
            "type": "object",
            "properties": {
              "monthly": { "type": "integer" },
              "currency": { "type": "string", "pattern": "^[A-Z]{3}$" }
            }
          },
          "digitalNomadSpecific": { "type": "boolean" },
          "chineseCitizenEligible": { "type": "boolean" },
          "rating": { "type": "number", "minimum": 0, "maximum": 5 }
        }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["version", "lastUpdated"],
      "properties": {
        "version": { "type": "string" },
        "lastUpdated": { "type": "string", "format": "date-time" },
        "disclaimer": {
          "type": "object",
          "properties": {
            "zh": { "type": "string" },
            "en": { "type": "string" }
          }
        }
      }
    }
  }
}
