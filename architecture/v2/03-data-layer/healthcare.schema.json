{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/kfat77/digital-nomad-cn/schemas/v2/quality/healthcare.schema.json",
  "title": "Healthcare",
  "description": "医疗体系数据。",
  "version": "2.0.0",
  "type": "object",
  "required": ["country", "system", "metadata"],
  "properties": {
    "country": { "type": "string" },
    "system": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["universal-public", "mixed", "private-primary", "insurance-mandated"]
        },
        "quality": {
          "type": "string",
          "enum": ["world-class", "excellent", "good", "adequate", "poor"]
        },
        "publicCoverage": {
          "type": "object",
          "properties": {
            "available": { "type": "boolean" },
            "forForeigners": { "type": "boolean" },
            "cost": { "type": "string" },
            "waitingTime": { "type": "string" }
          }
        }
      }
    },
    "facilities": {
      "type": "object",
      "properties": {
        "internationalHospitals": { "type": "boolean" },
        "englishSpeakingDoctors": { "type": "boolean" },
        "chineseSpeakingDoctors": { "type": "boolean" },
        "24hEmergency": { "type": "boolean" },
        "telemedicine": { "type": "boolean" }
      }
    },
    "costs": {
      "type": "object",
      "properties": {
        "currency": { "type": "string", "pattern": "^[A-Z]{3}$", "default": "USD" },
        "gpVisit": { "type": "integer" },
        "specialist": { "type": "integer" },
        "emergencyRoom": { "type": "integer" },
        "hospitalNight": { "type": "integer" },
        "dentalCleaning": { "type": "integer" },
        "prescription": { "type": "integer" }
      }
    },
    "insurance": {
      "type": "object",
      "properties": {
        "mandatory": { "type": "boolean" },
        "travelInsuranceAccepted": { "type": "boolean" },
        "recommendedProviders": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "coverage": { "type": "string" },
              "monthlyCost": { "type": "integer" }
            }
          }
        }
      }
    },
    "vaccinations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "required": { "type": "boolean" },
          "recommended": { "type": "boolean" }
        }
      }
    },
    "waterSafety": {
      "type": "string",
      "enum": ["tap-safe", "tap-treated", "bottled-only"]
    },
    "airQuality": {
      "type": "object",
      "properties": {
        "aqiAverage": { "type": "integer" },
        "status": { "type": "string", "enum": ["good", "moderate", "unhealthy-sensitive", "unhealthy", "very-unhealthy", "hazardous"] },
        "seasonalVariation": { "type": "boolean" }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["version", "lastUpdated"],
      "properties": {
        "version": { "type": "string" },
        "lastUpdated": { "type": "string", "format": "date-time" },
        "disclaimer": {
          "type": "object",
          "properties": {
            "zh": { "type": "string" },
            "en": { "type": "string" }
          }
        }
      }
    }
  }
}
