{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/kfat77/digital-nomad-cn/schemas/v2/living/salary.schema.json",
  "title": "Salary",
  "description": "本地薪资水平数据。按国家和城市，分职业类型。",
  "version": "2.0.0",
  "type": "object",
  "required": ["location", "currency", "salaries", "metadata"],
  "properties": {
    "location": {
      "type": "object",
      "required": ["country"],
      "properties": {
        "country": { "type": "string" },
        "city": { "type": "string" }
      }
    },
    "currency": { "type": "string", "pattern": "^[A-Z]{3}$", "default": "USD" },
    "referenceDate": { "type": "string", "format": "date" },
    "salaries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["role", "annual"],
        "properties": {
          "role": {
            "type": "string",
            "description": "职位类型",
            "enum": [
              "software-engineer", "product-manager", "designer",
              "data-scientist", "marketing", "sales",
              "teacher", "translator", "writer",
              "customer-service", "admin", "general-labor"
            ]
          },
          "level": {
            "type": "string",
            "enum": ["entry", "mid", "senior", "lead"]
          },
          "annual": {
            "type": "object",
            "properties": {
              "min": { "type": "integer" },
              "median": { "type": "integer" },
              "max": { "type": "integer" }
            }
          },
          "monthly": {
            "type": "object",
            "properties": {
              "min": { "type": "integer" },
              "median": { "type": "integer" },
              "max": { "type": "integer" }
            }
          },
          "notes": { "type": "string" }
        }
      }
    },
    "minimumWage": {
      "type": "object",
      "properties": {
        "monthly": { "type": "integer" },
        "hourly": { "type": "integer" },
        "currency": { "type": "string", "pattern": "^[A-Z]{3}$" }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["version", "lastUpdated"],
      "properties": {
        "version": { "type": "string" },
        "lastUpdated": { "type": "string", "format": "date-time" },
        "dataSource": { "type": "string" }
      }
    }
  }
}
