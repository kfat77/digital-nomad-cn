{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/kfat77/digital-nomad-cn/schemas/v2/core/city.schema.json",
  "title": "City",
  "description": "数字游民城市数据。每个城市关联一个国家。",
  "version": "2.0.0",
  "type": "object",
  "required": ["id", "name", "country", "coordinates", "status", "metadata"],
  "properties": {
    "id": {
      "type": "string",
      "description": "城市唯一标识符，使用slug格式",
      "examples": ["bangkok", "tokyo", "lisbon", "chiang-mai"],
      "pattern": "^[a-z][a-z0-9-]+$"
    },
    "name": {
      "type": "object",
      "required": ["zh", "en"],
      "properties": {
        "zh": { "type": "string" },
        "en": { "type": "string" },
        "local": { "type": "string" }
      }
    },
    "country": {
      "type": "string",
      "description": "所属国家ID（引用country.schema.json）",
      "examples": ["thailand", "japan", "portugal"]
    },
    "type": {
      "type": "string",
      "enum": ["capital", "major", "nomad-hub", "secondary", "resort"],
      "description": "城市类型"
    },
    "coordinates": {
      "type": "object",
      "properties": {
        "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
        "longitude": { "type": "number", "minimum": -180, "maximum": 180 }
      },
      "required": ["latitude", "longitude"]
    },
    "population": {
      "type": "integer",
      "description": "城市人口",
      "minimum": 0
    },
    "elevation": {
      "type": "integer",
      "description": "海拔高度（米）"
    },
    "climate": {
      "type": "object",
      "description": "气候特征",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["tropical", "subtropical", "temperate", "continental", "mediterranean", "desert", "alpine"]
        },
        "bestMonths": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}$" },
          "description": "最佳月份（YYYY-MM格式）"
        },
        "avoidMonths": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}$" },
          "description": "避免月份"
        }
      }
    },
    "nomadScore": {
      "type": "object",
      "description": "数字游民综合评分",
      "properties": {
        "overall": { "type": "integer", "minimum": 0, "maximum": 100 },
        "cost": { "type": "integer", "minimum": 0, "maximum": 100 },
        "internet": { "type": "integer", "minimum": 0, "maximum": 100 },
        "safety": { "type": "integer", "minimum": 0, "maximum": 100 },
        "fun": { "type": "integer", "minimum": 0, "maximum": 100 },
        "qualityOfLife": { "type": "integer", "minimum": 0, "maximum": 100 },
        "english": { "type": "integer", "minimum": 0, "maximum": 100 }
      }
    },
    "costOfLiving": {
      "type": "object",
      "description": "生活成本参考（美元/月）",
      "properties": {
        "budget": { "type": "integer", "description": "预算生活方式" },
        "moderate": { "type": "integer", "description": "中等生活方式" },
        "comfortable": { "type": "integer", "description": "舒适生活方式" },
        "currency": { "type": "string", "pattern": "^[A-Z]{3}$", "default": "USD" }
      }
    },
    "internet": {
      "type": "object",
      "properties": {
        "averageSpeed": { "type": "integer", "description": "平均网速(Mbps)" },
        "mobileSpeed": { "type": "integer", "description": "移动网速(Mbps)" },
        "fiberAvailable": { "type": "boolean" }
      }
    },
    "community": {
      "type": "object",
      "description": "数字游民社区",
      "properties": {
        "size": { "type": "string", "enum": ["small", "medium", "large", "very-large"] },
        "chineseCommunity": { "type": "boolean" },
        "meetups": { "type": "boolean" },
        "coworkingSpaces": { "type": "integer", "minimum": 0 }
      }
    },
    "visa": {
      "type": "object",
      "description": "签证相关信息",
      "properties": {
        "visaFreeDays": { "type": "integer", "description": "免签停留天数" },
        "visaOnArrival": { "type": "boolean" },
        "digitalNomadVisa": {
          "type": "object",
          "properties": {
            "available": { "type": "boolean" },
            "duration": { "type": "string", "examples": ["6 months", "1 year", "2 years"] },
            "incomeRequirement": {
              "type": "object",
              "properties": {
                "amount": { "type": "integer" },
                "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
                "period": { "type": "string", "enum": ["monthly", "annually"] }
              }
            }
          }
        }
      }
    },
    "safety": {
      "type": "object",
      "properties": {
        "level": { "type": "string", "enum": ["very-safe", "safe", "moderate", "caution", "avoid"] },
        "femaleSolo": { "type": "string", "enum": ["very-safe", "safe", "moderate", "caution", "avoid"] },
        "lgbt": { "type": "string", "enum": ["very-safe", "safe", "moderate", "caution", "avoid"] },
        "night": { "type": "string", "enum": ["very-safe", "safe", "moderate", "caution", "avoid"] }
      }
    },
    "healthcare": {
      "type": "object",
      "properties": {
        "quality": { "type": "string", "enum": ["excellent", "good", "adequate", "poor"] },
        "internationalHospitals": { "type": "boolean" },
        "englishSpeakingDoctors": { "type": "boolean" },
        "cost": { "type": "string", "enum": ["expensive", "moderate", "affordable", "very-cheap"] }
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "beach", "mountain", "city", "historical", "temple", "foodie",
          "nightlife", "nature", "surfing", "diving", "hiking", "skiing",
          "budget-friendly", "luxury", "family-friendly", "lgbt-friendly",
          "fast-wifi", "coffee-culture", "street-food", "shopping"
        ]
      }
    },
    "status": {
      "type": "string",
      "enum": ["active", "draft", "deprecated", "pending-review"],
      "default": "draft"
    },
    "metadata": {
      "type": "object",
      "required": ["version", "lastUpdated"],
      "properties": {
        "version": { "type": "string" },
        "lastUpdated": { "type": "string", "format": "date-time" },
        "contributors": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "github": { "type": "string" },
              "name": { "type": "string" },
              "role": { "type": "string", "enum": ["author", "maintainer", "contributor"] }
            }
          }
        },
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "url": { "type": "string", "format": "uri" }
            }
          }
        }
      }
    }
  }
}
