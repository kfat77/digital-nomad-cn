{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/kfat77/digital-nomad-cn/schemas/v2/mobility/visa.schema.json",
  "title": "Visa",
  "description": "签证类型与政策数据。按国家对定义，支持多语言。",
  "version": "2.0.0",
  "type": "object",
  "required": ["country", "visas", "metadata"],
  "properties": {
    "country": {
      "type": "string",
      "description": "目标国家ID（引用country.schema.json）"
    },
    "visas": {
      "type": "array",
      "description": "该国提供的所有签证类型",
      "items": {
        "type": "object",
        "required": ["id", "name", "type", "eligibility"],
        "properties": {
          "id": {
            "type": "string",
            "description": "签证类型唯一ID",
            "examples": ["tourist-visa", "digital-nomad-visa", "work-visa", "student-visa"]
          },
          "name": {
            "type": "object",
            "required": ["zh", "en"],
            "properties": {
              "zh": { "type": "string" },
              "en": { "type": "string" }
            }
          },
          "type": {
            "type": "string",
            "description": "签证大类",
            "enum": [
              "visa-free", "visa-on-arrival", "e-visa", "tourist-visa",
              "digital-nomad-visa", "work-visa", "business-visa",
              "student-visa", "retirement-visa", "investment-visa",
              "family-visa", "transit-visa", "working-holiday"
            ]
          },
          "eligibility": {
            "type": "array",
            "description": "适用护照国家列表（ISO alpha-3）",
            "items": { "type": "string", "pattern": "^[A-Z]{3}$" }
          },
          "notEligible": {
            "type": "array",
            "description": "明确不适用的护照国家",
            "items": { "type": "string", "pattern": "^[A-Z]{3}$" }
          },
          "duration": {
            "type": "object",
            "description": "停留时长",
            "properties": {
              "maxDays": { "type": "integer", "minimum": 0 },
              "maxMonths": { "type": "integer", "minimum": 0 },
              "singleEntry": { "type": "boolean", "description": "是否单次入境" },
              "multipleEntry": { "type": "boolean", "description": "是否多次入境" },
              "extendable": { "type": "boolean", "description": "是否可延期" },
              "extensionDays": { "type": "integer", "description": "可延期天数" }
            }
          },
          "requirements": {
            "type": "object",
            "description": "申请要求",
            "properties": {
              "passportValidity": { "type": "string", "examples": ["6 months", "3 months"] },
              "blankPages": { "type": "integer", "description": "护照空白页要求" },
              "photos": { "type": "integer", "description": "照片数量" },
              "proofOfFunds": {
                "type": "object",
                "properties": {
                  "required": { "type": "boolean" },
                  "minAmount": { "type": "integer" },
                  "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
                  "period": { "type": "string", "enum": ["daily", "monthly", "total"] }
                }
              },
              "proofOfAccommodation": { "type": "boolean" },
              "returnTicket": { "type": "boolean" },
              "travelInsurance": { "type": "boolean" },
              "vaccination": {
                "type": "array",
                "items": { "type": "string", "examples": ["yellow-fever", "covid-19"] }
              },
              "invitationLetter": { "type": "boolean" },
              "sponsor": { "type": "boolean" },
              "bankStatement": { "type": "boolean" },
              "employmentProof": { "type": "boolean" },
              "incomeProof": {
                "type": "object",
                "properties": {
                  "required": { "type": "boolean" },
                  "minMonthlyIncome": { "type": "integer" },
                  "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
                  "source": { "type": "string", "enum": ["employment", "freelance", "investment", "retirement"] }
                }
              },
              "criminalRecord": { "type": "boolean" },
              "medicalExam": { "type": "boolean" }
            }
          },
          "cost": {
            "type": "object",
            "description": "签证费用",
            "properties": {
              "amount": { "type": "integer" },
              "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
              "notes": { "type": "string" }
            }
          },
          "processingTime": {
            "type": "object",
            "description": "处理时间",
            "properties": {
              "minDays": { "type": "integer" },
              "maxDays": { "type": "integer" },
              "expressAvailable": { "type": "boolean" },
              "expressDays": { "type": "integer" }
            }
          },
          "applicationMethods": {
            "type": "array",
            "description": "申请方式",
            "items": {
              "type": "string",
              "enum": ["online", "embassy", "consulate", "visa-center", "on-arrival", "e-visa-portal"]
            }
          },
          "renewal": {
            "type": "object",
            "description": "续签信息",
            "properties": {
              "allowed": { "type": "boolean" },
              "maxRenewals": { "type": "integer" },
              "conditions": { "type": "string" }
            }
          },
          "workAllowed": { "type": "boolean", "description": "是否允许工作" },
          "studyAllowed": { "type": "boolean", "description": "是否允许学习" },
          "pathToResidency": {
            "type": "boolean",
            "description": "是否有转永居路径"
          },
          "notes": {
            "type": "object",
            "properties": {
              "zh": { "type": "string" },
              "en": { "type": "string" }
            }
          },
          "officialUrl": { "type": "string", "format": "uri" },
          "status": {
            "type": "string",
            "enum": ["active", "suspended", "changed", "upcoming"],
            "default": "active"
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["version", "lastUpdated"],
      "properties": {
        "version": { "type": "string" },
        "lastUpdated": { "type": "string", "format": "date-time" },
        "disclaimer": {
          "type": "object",
          "properties": {
            "zh": { "type": "string" },
            "en": { "type": "string" }
          }
        },
        "contributors": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "github": { "type": "string" },
              "name": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
