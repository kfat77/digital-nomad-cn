{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/kfat77/digital-nomad-cn/schemas/v2/infrastructure/internet.schema.json",
  "title": "Internet",
  "description": "网络质量数据。包含固定宽带和移动网络。",
  "version": "2.0.0",
  "type": "object",
  "required": ["location", "broadband", "mobile", "metadata"],
  "properties": {
    "location": {
      "type": "object",
      "required": ["country"],
      "properties": {
        "country": { "type": "string" },
        "city": { "type": "string" }
      }
    },
    "broadband": {
      "type": "object",
      "properties": {
        "averageSpeed": { "type": "number", "description": "平均下载速度(Mbps)" },
        "medianSpeed": { "type": "number" },
        "uploadSpeed": { "type": "number" },
        "latency": { "type": "number", "description": "延迟(ms)" },
        "jitter": { "type": "number" },
        "packetLoss": { "type": "number", "description": "丢包率(%)" },
        "fiberCoverage": { "type": "number", "description": "光纤覆盖率(%)" },
        "providers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "plans": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "speed": { "type": "string", "examples": ["100Mbps", "1Gbps"] },
                    "price": { "type": "integer" },
                    "currency": { "type": "string", "pattern": "^[A-Z]{3}$" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "mobile": {
      "type": "object",
      "properties": {
        "averageSpeed": { "type": "number", "description": "平均下载速度(Mbps)" },
        "uploadSpeed": { "type": "number" },
        "latency": { "type": "number" },
        "coverage": { "type": "number", "description": "覆盖率(%)" },
        "5gAvailable": { "type": "boolean" },
        "esimAvailable": { "type": "boolean" },
        "touristSim": {
          "type": "object",
          "properties": {
            "available": { "type": "boolean" },
            "priceRange": {
              "type": "object",
              "properties": {
                "min": { "type": "integer" },
                "max": { "type": "integer" },
                "currency": { "type": "string", "pattern": "^[A-Z]{3}$" }
              }
            },
            "dataAllowance": { "type": "string", "examples": ["10GB", "unlimited"] },
            "validity": { "type": "string", "examples": ["7 days", "30 days"] }
          }
        },
        "providers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "coverage": { "type": "string", "enum": ["excellent", "good", "fair", "poor"] }
            }
          }
        }
      }
    },
    "censorship": {
      "type": "object",
      "description": "网络审查情况",
      "properties": {
        "level": {
          "type": "string",
          "enum": ["none", "minimal", "moderate", "heavy", "severe"]
        },
        "vpnRequired": { "type": "boolean" },
        "blockedServices": {
          "type": "array",
          "items": { "type": "string" },
          "examples": ["google", "facebook", "twitter", "chatgpt"]
        }
      }
    },
    "remoteWorkSuitability": {
      "type": "object",
      "properties": {
        "videoCalls": { "type": "string", "enum": ["excellent", "good", "fair", "poor"] },
        "fileSharing": { "type": "string", "enum": ["excellent", "good", "fair", "poor"] },
        "cloudAccess": { "type": "string", "enum": ["excellent", "good", "fair", "poor"] }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["version", "lastUpdated"],
      "properties": {
        "version": { "type": "string" },
        "lastUpdated": { "type": "string", "format": "date-time" },
        "dataSource": { "type": "string" }
      }
    }
  }
}
