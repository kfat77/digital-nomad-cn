{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/kfat77/digital-nomad-cn/schemas/v2/living/tax.schema.json",
  "title": "Tax",
  "description": "税务规则数据。描述各国的税务居民认定、税率、数字游民税务处理等。",
  "version": "2.0.0",
  "type": "object",
  "required": ["country", "residencyRules", "taxRates", "metadata"],
  "properties": {
    "country": {
      "type": "string",
      "description": "国家ID（引用country.schema.json）"
    },
    "digitalNomadFriendly": {
      "type": "boolean",
      "description": "是否对数字游民税务友好"
    },
    "residencyRules": {
      "type": "object",
      "description": "税务居民认定规则",
      "properties": {
        "physicalPresence": {
          "type": "object",
          "description": "物理居住测试",
          "properties": {
            "daysThreshold": { "type": "integer", "description": "年度居住天数阈值" },
            "consecutiveDays": { "type": "integer", "description": "连续居住天数阈值" },
            "calculationMethod": {
              "type": "string",
              "enum": ["calendar-year", "rolling-365", "any-12-months"]
            }
          }
        },
        "domicile": {
          "type": "boolean",
          "description": "是否有住所认定"
        },
        "centerOfVitalInterests": {
          "type": "boolean",
          "description": "是否有生活重心认定"
        },
        "habitualAbode": {
          "type": "boolean",
          "description": "是否有习惯性居所认定"
        },
        "citizenship": {
          "type": "boolean",
          "description": "公民身份是否触发纳税义务"
        }
      }
    },
    "taxRates": {
      "type": "object",
      "description": "税率结构",
      "properties": {
        "incomeTax": {
          "type": "object",
          "description": "个人所得税",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["progressive", "flat", "territorial", "zero"]
            },
            " brackets": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "min": { "type": "integer" },
                  "max": { "type": "integer" },
                  "rate": { "type": "number", "minimum": 0, "maximum": 1 }
                }
              }
            },
            "flatRate": { "type": "number", "minimum": 0, "maximum": 1 },
            "standardDeduction": {
              "type": "object",
              "properties": {
                "amount": { "type": "integer" },
                "currency": { "type": "string", "pattern": "^[A-Z]{3}$" }
              }
            }
          }
        },
        "capitalGains": {
          "type": "object",
          "properties": {
            "rate": { "type": "number", "minimum": 0, "maximum": 1 },
            "exemptAmount": { "type": "integer" },
            "holdingPeriodExemption": { "type": "integer", "description": "持有多久免税（月）" }
          }
        },
        "vat": {
          "type": "object",
          "properties": {
            "rate": { "type": "number", "minimum": 0, "maximum": 1 },
            "reducedRate": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "socialSecurity": {
          "type": "object",
          "properties": {
            "employeeRate": { "type": "number", "minimum": 0, "maximum": 1 },
            "employerRate": { "type": "number", "minimum": 0, "maximum": 1 },
            "selfEmployedRate": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        }
      }
    },
    "foreignIncome": {
      "type": "object",
      "description": "境外收入处理",
      "properties": {
        "taxed": { "type": "boolean", "description": "境外收入是否应税" },
        "remittanceBasis": { "type": "boolean", "description": "是否按汇款基础征税" },
        "territorialSystem": { "type": "boolean", "description": "是否属地征税制" },
        "foreignTaxCredit": { "type": "boolean", "description": "是否有外国税收抵免" }
      }
    },
    "digitalNomadSpecific": {
      "type": "object",
      "description": "数字游民税务特殊规则",
      "properties": {
        "nomadVisaTaxExemption": { "type": "boolean" },
        "nomadVisaTaxExemptionDuration": { "type": "string" },
        "remoteWorkClarification": { "type": "string" },
        "doubleTaxationTreaties": {
          "type": "array",
          "items": { "type": "string", "description": "DTT协议国家" }
        }
      }
    },
    "specialPrograms": {
      "type": "array",
      "description": "特殊税务计划",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "eligibleIncomeTypes": {
            "type": "array",
            "items": { "type": "string" }
          },
          "maxDuration": { "type": "string" },
          "benefits": { "type": "string" }
        }
      }
    },
    "notes": {
      "type": "object",
      "properties": {
        "zh": { "type": "string" },
        "en": { "type": "string" }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["version", "lastUpdated"],
      "properties": {
        "version": { "type": "string" },
        "lastUpdated": { "type": "string", "format": "date-time" },
        "disclaimer": {
          "type": "object",
          "properties": {
            "zh": { "type": "string" },
            "en": { "type": "string" }
          }
        },
        "contributors": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "github": { "type": "string" },
              "name": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
