{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/kfat77/digital-nomad-cn/schemas/v2/quality/safety.schema.json",
  "title": "Safety",
  "description": "安全指数与犯罪率数据。",
  "version": "2.0.0",
  "type": "object",
  "required": ["location", "overall", "metadata"],
  "properties": {
    "location": {
      "type": "object",
      "required": ["country"],
      "properties": {
        "country": { "type": "string" },
        "city": { "type": "string" }
      }
    },
    "overall": {
      "type": "object",
      "properties": {
        "score": { "type": "integer", "minimum": 0, "maximum": 100 },
        "level": {
          "type": "string",
          "enum": ["very-safe", "safe", "moderate", "caution", "dangerous"]
        },
        "globalRank": { "type": "integer" }
      }
    },
    "categories": {
      "type": "object",
      "properties": {
        "violentCrime": { "type": "integer", "minimum": 0, "maximum": 100 },
        "propertyCrime": { "type": "integer", "minimum": 0, "maximum": 100 },
        "corruption": { "type": "integer", "minimum": 0, "maximum": 100 },
        "politicalStability": { "type": "integer", "minimum": 0, "maximum": 100 },
        "terrorismRisk": { "type": "integer", "minimum": 0, "maximum": 100 },
        "naturalDisaster": { "type": "integer", "minimum": 0, "maximum": 100 }
      }
    },
    "specific": {
      "type": "object",
      "properties": {
        "femaleSolo": {
          "type": "object",
          "properties": {
            "score": { "type": "integer", "minimum": 0, "maximum": 100 },
            "level": { "type": "string", "enum": ["very-safe", "safe", "moderate", "caution", "dangerous"] },
            "notes": {
              "type": "object",
              "properties": {
                "zh": { "type": "string" },
                "en": { "type": "string" }
              }
            }
          }
        },
        "lgbt": {
          "type": "object",
          "properties": {
            "score": { "type": "integer", "minimum": 0, "maximum": 100 },
            "level": { "type": "string", "enum": ["very-safe", "safe", "moderate", "caution", "dangerous"] },
            "legalStatus": {
              "type": "object",
              "properties": {
                "sameSexMarriage": { "type": "boolean" },
                "civilUnion": { "type": "boolean" },
                "antiDiscrimination": { "type": "boolean" }
              }
            }
          }
        },
        "night": {
          "type": "object",
          "properties": {
            "score": { "type": "integer", "minimum": 0, "maximum": 100 },
            "areasToAvoid": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "scams": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string" },
              "description": {
                "type": "object",
                "properties": {
                  "zh": { "type": "string" },
                  "en": { "type": "string" }
                }
              },
              "prevention": {
                "type": "object",
                "properties": {
                  "zh": { "type": "string" },
                  "en": { "type": "string" }
                }
              }
            }
          }
        }
      }
    },
    "emergencyNumbers": {
      "type": "object",
      "properties": {
        "police": { "type": "string" },
        "ambulance": { "type": "string" },
        "fire": { "type": "string" },
        "touristPolice": { "type": "string" }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["version", "lastUpdated"],
      "properties": {
        "version": { "type": "string" },
        "lastUpdated": { "type": "string", "format": "date-time" },
        "dataSource": { "type": "string" }
      }
    }
  }
}
