{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/kfat77/digital-nomad-cn/schemas/v2/infrastructure/cowork.schema.json",
  "title": "CoworkingSpace",
  "description": "联合办公空间数据。按国家和城市定义。",
  "version": "2.0.0",
  "type": "object",
  "required": ["country", "city", "spaces", "metadata"],
  "properties": {
    "country": { "type": "string", "description": "国家ID" },
    "city": { "type": "string", "description": "城市ID" },
    "spaces": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "coordinates"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "address": { "type": "string" },
          "coordinates": {
            "type": "object",
            "properties": {
              "latitude": { "type": "number" },
              "longitude": { "type": "number" }
            }
          },
          "website": { "type": "string", "format": "uri" },
          "pricing": {
            "type": "object",
            "properties": {
              "dayPass": { "type": "integer" },
              "weekly": { "type": "integer" },
              "monthly": { "type": "integer" },
              "currency": { "type": "string", "pattern": "^[A-Z]{3}$" }
            }
          },
          "amenities": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "wifi", "high-speed-wifi", "ethernet", "power-outlets",
                "coffee", "kitchen", "meeting-rooms", "phone-booths",
                "standing-desks", "ergonomic-chairs", "24-7-access",
                "lockers", "shower", "nap-room", "event-space",
                "printer", "scanner", "monitor-rental", "bike-storage",
                "pet-friendly", "outdoor-space", "rooftop"
              ]
            }
          },
          "atmosphere": {
            "type": "string",
            "enum": ["quiet", "social", "corporate", "creative", "relaxed"]
          },
          "rating": {
            "type": "object",
            "properties": {
              "overall": { "type": "number", "minimum": 0, "maximum": 5 },
              "wifi": { "type": "number", "minimum": 0, "maximum": 5 },
              "comfort": { "type": "number", "minimum": 0, "maximum": 5 },
              "community": { "type": "number", "minimum": 0, "maximum": 5 }
            }
          },
          "chineseFriendly": { "type": "boolean" },
          "openingHours": { "type": "string" },
          "status": { "type": "string", "enum": ["active", "closed", "moved"], "default": "active" }
        }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["version", "lastUpdated"],
      "properties": {
        "version": { "type": "string" },
        "lastUpdated": { "type": "string", "format": "date-time" },
        "contributors": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "github": { "type": "string" },
              "name": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
