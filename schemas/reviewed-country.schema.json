{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/kfat77/digital-nomad-cn/schemas/reviewed-country.schema.json",
  "title": "Reviewed Country Record",
  "description": "A scoped review record. It never asserts that every country metric is official or current.",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": ["country_id", "reviewed_fields", "last_reviewed_at", "sources"],
    "properties": {
    "country_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]+$" },
    "reviewed_fields": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "enum": ["visa_entry", "digital_nomad_visa", "banking", "securities"] }
    },
    "last_reviewed_at": { "type": "string", "format": "date-time" },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["field", "name", "url", "source_type"],
        "properties": {
          "field": { "type": "string" },
          "name": { "type": "string" },
          "url": { "type": "string", "format": "uri", "pattern": "^https://" },
          "source_type": { "type": "string", "const": "official" }
        }
      }
    },
    "review_note": { "type": "string" }
    },
    "additionalProperties": false
  }
}
